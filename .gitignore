# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/.playwright-cli/
/output/

# local env files
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel (unused — site deploys to Hostinger)
.vercel

# deploy archives (temporary)
*.tar.gz

# claude code — local/per-machine settings (also covered by a global
# gitignore, but listed here too so a fresh clone is safe without it)
.claude/settings.local.json

# temp/ is an intake-only staging folder — files dropped here for
# processing shouldn't get auto-committed. Move anything worth keeping to
# public/ (served) or assets/originals/ (source) instead. See temp/README.md.
/temp/*
!/temp/README.md
